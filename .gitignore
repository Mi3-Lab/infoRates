evaluations/accv2026/fixed_budget/
evaluations/accv2026/metrics/

# Keep small reproducibility manifests visible to git.
!evaluations/accv2026/
!evaluations/accv2026/manifests/
!evaluations/accv2026/manifests/*.csv

